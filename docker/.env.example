# Copy to docker/.env and edit. docker/.env is gitignored.

# PostgreSQL
DB_NAME=moodle
DB_USER=moodle
DB_PASS=change-me

# Moodle admin account (created on first boot)
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=change-me-Strong1!
MOODLE_ADMIN_EMAIL=admin@example.com

# Site — NO SPACES in the sitename: the image's install script passes it
# unquoted to install.php, so spaces break first-boot install. Rename in the
# admin UI afterwards if you want a pretty name.
MOODLE_SITENAME=MCP_Learning_Lab
MOODLE_PORT=8080

# Keycloak admin console (Phase 5) — http://localhost:8081
KC_ADMIN_USER=admin
KC_ADMIN_PASS=change-me-kc
